# Optional network settings if your machine requires a proxy or private package mirrors.
# Uncomment and customize as needed before running setup scripts.

# export HTTP_PROXY=http://<proxy-host>:<proxy-port>
# export HTTPS_PROXY=http://<proxy-host>:<proxy-port>
# export PIP_INDEX_URL=https://<your-pypi-mirror>/simple
# npm config set registry https://<your-npm-mirror>
